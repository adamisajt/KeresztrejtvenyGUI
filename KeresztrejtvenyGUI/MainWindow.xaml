<Window x:Class="KeresztrejtvenyGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KeresztrejtvenyGUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="600">
    <StackPanel Margin="15">

        <StackPanel Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="keresztrejtveny merete [sor x oszlop]:" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbSor" Width="60" Margin="5"/>
            <ComboBox x:Name="cbOszlop" Width="60" Margin="5"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10">
            <Button Content="Letrehozas"
                Click="Letrehoz_Click"
                Margin="0,0,10,0"/>

            <Button Content="Mentes"
                Click="Mentes_Click"
                Margin="0,0,10,0"/>

            <ComboBox x:Name="cbIndex" Width="50"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <UniformGrid x:Name="gridRacs"/>
        </ScrollViewer>

    </StackPanel>
</Window>
